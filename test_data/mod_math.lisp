(defun abs (n)
    (if (< n 0)
        (- 0 n)
        n))
(defun frac (n) (- n (truncate n)))
(defun floor (n)
    (truncate
        (if (< n 0)
            (- n 1)
            n)))
(defun ceiling (n) (- 0 (floor (- 0 n))))
(defun round (n) (floor (+ n 0.5)))
(defun mod (n m) (- n (* m (truncate (/ n m)))))
(defun gcd (n m)
    (if (equal m 0)
        n
        (gcd m (mod n m))))
(defun lcm (n m) (/ (* n m) (gcd n m)))
(defun even? (n) (equal (mod n 2) 0))
(defun odd? (n) (equal (mod n 2) 1))
