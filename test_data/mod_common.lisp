(defvar null? not)
(defun err? (x) (equal x 'ERR))
(defun number? (x) (equal (* 0 x) 0))
(defun symbol? (x)
    (and
        x
        (not (err? x))
        (not (number? x))
        (not (consp x))))
(defun atom? (x)
    (or
        (not x)
        (symbol? x)))
(defun list? (x)
    (if (consp x)
        (list? (cdr x))
        (not x)))
(defun equal? (x y)
    (or
        (equal x y)
        (and
            (consp x)
            (consp y)
            (equal? (car x) (car y))
            (equal? (cdr x) (cdr y)))))
(defun negate (n) (- 0 n))
(defvar > (lambda (x y) (< y x)))
(defvar <= (lambda (x y) (not (< y x))))
(defvar >= (lambda (x y) (not (< x y))))
(defun = (x y) (equal (- x y) 0))
(defvar list (lambda args args))
(defun cadr (x) (car (cdr x)))
(defun caddr (x) (car (cdr (cdr x))))
(defvar begin (lambda (x . args) (if args (begin . args) x)))
